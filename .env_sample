# Impulse -- Environment Variables
# Copy this file to .env and fill in your values.

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Direct connection string (for local dev). In production, use MONGODB_SECRET_ID instead.
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_DATABASE=praxis

# AWS Secrets Manager secret ID containing the MongoDB URI (for Lambda/ECS).
# MONGODB_SECRET_ID=impulse/mongodb-uri

# ── S3 ───────────────────────────────────────────────────────────────────────
IMPULSE_BUCKET=impulse-documents

# ── Amazon Bedrock ───────────────────────────────────────────────────────────
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_REGION=us-east-1

# ── EC2 Orchestrator ─────────────────────────────────────────────────────────
# Path to the orchestrator YAML config file (default: ec2_config.yaml)
# EC2_CONFIG_PATH=ec2_config.yaml

# These can also be set in ec2_config.yaml; env vars take precedence.
# EC2_AMI_ID=ami-XXXXXXXXXXXXXXXXX
# EC2_REGION=us-east-2
# EC2_SUBNET_ID=subnet-XXXXXXXXX
# EC2_SECURITY_GROUP_IDS=sg-XXXXXXXXX
# EC2_IAM_INSTANCE_PROFILE=impulse-worker-profile
# EC2_KEY_NAME=impulse-debug
# EC2_MAX_INSTANCES=5
# EC2_IDLE_TIMEOUT=300
# EC2_MAX_WALLTIME=43200

# ── Step Functions (set automatically by CDK in Lambda env) ──────────────────
# STATE_MACHINE_ARN=arn:aws:states:us-east-1:123456789012:stateMachine:impulse-document-pipeline
